{
  "name": "vcd",
  "version": "0.1.0",
  "private": true,
  "description": "NCAA Volleyball Coach Dynasty — single-player career-coach dynasty simulation",
  "author": "Matt <matt@k-analytics.com>",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20.0.0"
  },
  "main": "main/dist/index.js",
  "workspaces": [
    "shared",
    "main",
    "workers",
    "app"
  ],
  "scripts": {
    "dev": "concurrently -k -n vite,electron -c blue,magenta \"npm -w app run dev\" \"cross-env VCD_DEV=1 npm -w main run dev\"",
    "build": "npm -w shared run build && npm -w workers run build && npm -w main run build && npm -w app run build",
    "build:installer": "npm run build && electron-builder --win --config electron-builder.yml",
    "test": "vitest run --exclude tests/integration/season/weekPerf.test.ts --exclude tests/integration/season/memoryLeak.test.ts --exclude tests/integration/season/seasonAdvancePerf.test.ts --exclude tests/integration/dynasty/**",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:calibration": "vitest run tests/integration/sim/sideOutRate.test.ts",
    "test:calibration:full": "vitest run tests/integration/sim/sideOutRateFull.test.ts",
    "test:calibration-season": "vitest run tests/integration/calibration/seasonCalibration.test.ts",
    "calibrate:run": "tsx scripts/calibrate-season.ts",
    "prebench": "npm -w shared run build",
    "bench": "tsx scripts/bench-rally.ts",
    "clean": "rimraf \"**/*.tsbuildinfo\" shared/dist workers/dist main/dist app/dist",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:reset": "prisma migrate reset --force --skip-seed",
    "seed": "tsx prisma/seed.ts",
    "lint": "eslint . --ext .ts,.tsx --max-warnings 0",
    "typecheck": "tsc -b",
    "check": "npm run lint && npm run typecheck",
    "test:repeat": "vitest run && vitest run && vitest run",
    "test:season": "vitest run tests/integration/poll/pollInvariants.test.ts",
    "test:bracket": "vitest run tests/integration/bracket/bracketInvariants.test.ts",
    "test:postseason": "vitest run tests/integration/postseason/fullPostseason.test.ts",
    "test:recruiting-sim": "vitest run tests/integration/recruiting/fullCycle.test.ts",
    "test:portal-sim": "vitest run tests/integration/portal/fullCycle.test.ts",
    "test:nil-sim": "vitest run tests/integration/nil/fullCycle.test.ts",
    "test:perf": "vitest run tests/integration/season/weekPerf.test.ts && vitest run tests/integration/season/memoryLeak.test.ts && vitest run tests/integration/season/seasonAdvancePerf.test.ts",
    "test:dynasty-10": "vitest run tests/integration/dynasty/save10Seasons.test.ts",
    "test:perf-long": "cross-env NODE_OPTIONS=--expose-gc vitest run tests/integration/dynasty/memoryLeak20Seasons.test.ts",
    "test:offseason-sim": "vitest run tests/integration/offseason/fullCycle.test.ts",
    "test:coaching-sim": "vitest run tests/integration/coaching/fullCycle.test.ts",
    "test:awards-sim": "vitest run tests/integration/awards/composition.exit.test.ts tests/integration/awards/topHittersInAA.exit.test.ts",
    "test:matchhub-sim": "vitest run tests/integration/match/scoutReport.test.ts tests/unit/app/replayScheduler.test.ts",
    "test:analytics-sim": "vitest run tests/integration/analytics/crossValidation.test.ts tests/unit/analytics/",
    "test:a11y-e2e": "playwright test tests/e2e/programBuildingA11y.spec.ts",
    "format": "prettier --check .",
    "format:write": "prettier --write ."
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.17.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.15.0",
    "@typescript-eslint/parser": "^8.15.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^2.1.5",
    "axe-playwright": "^2.2.2",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.0.0",
    "jest-axe": "^9.0.0",
    "jsdom": "^25.0.1",
    "prettier": "^3.4.1",
    "prisma": "^5.22.0",
    "rimraf": "^6.1.3",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^2.1.5"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.23.8",
    "zustand": "^5.0.1"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
