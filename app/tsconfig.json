{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "outDir": "./.tsbuild",
    "rootDir": "./src",
    "types": ["node", "vite/client"],
    "emitDeclarationOnly": true
  },
  "include": ["src/**/*"],
  "exclude": ["dist", ".tsbuild", "**/*.test.ts", "**/*.test.tsx"],
  "references": [{ "path": "../shared" }]
}
